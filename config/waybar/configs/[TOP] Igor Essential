{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "passthrough": false,
  "fixed-center": true,
  "spacing": 6,
  "height": 26,
  "margin-top": 2,
  "margin-left": 8,
  "margin-right": 8,

  "modules-left": [
    "custom/calendar",
    "clock#time",
    "clock#date",
    "custom/hour-glyph"
  ],

  "modules-center": [
    "hyprland/workspaces",
    "custom/workspace-add"
  ],

  "modules-right": [
    "custom/launcher",
    "custom/terminal",
    "custom/files",
    "custom/swaync"
  ],

  "custom/launcher": {
    "format": "🚀",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/RofiLauncher.sh"
  },

  "custom/terminal": {
    "format": "📜",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/WaybarTerminal.sh"
  },

  "custom/calendar": {
    "format": "📅",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/WaybarCalendar.sh"
  },

  "clock#time": {
    "interval": 30,
    "tooltip": false,
    "format": "{:%H:%M}"
  },

  "clock#date": {
    "interval": 30,
    "tooltip": false,
    "format": "{:%d/%m/%Y}"
  },

  "custom/hour-glyph": {
    "exec": "$HOME/.config/hypr/scripts/WaybarHourGlyph.sh",
    "interval": 60,
    "tooltip": false,
    "format": "{}"
  },

  "hyprland/workspaces": {
    "all-outputs": false,
    "show-special": false,
    "tooltip": false,
    "on-click": "hyprctl dispatch workspace name:{name}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format": "{icon}",
    "format-icons": {
      "active": "🟢",
      "default": "⚪"
    }
  },

  "custom/workspace-add": {
    "format": "➕",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/WaybarAddWorkspace.sh"
  },

  "custom/swaync": {
    "format": "⚙️",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/SwayncPanel.sh toggle",
    "on-click-right": "$HOME/.config/hypr/scripts/SwayncPanel.sh dnd"
  },

  "custom/files": {
    "format": "📑",
    "tooltip": false,
    "on-click": "nautilus --new-window"
  }
}

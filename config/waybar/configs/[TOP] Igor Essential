{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "passthrough": false,
  "fixed-center": true,
  "spacing": 6,
  "height": 30,
  "margin-top": 2,
  "margin-left": 8,
  "margin-right": 8,

  "modules-left": [
    "custom/calendar",
    "custom/launcher",
    "clock#time",
    "clock#date",
    "custom/hour-glyph"
  ],

  "modules-center": [
    "custom/workspace-prev",
    "custom/workspace-num",
    "custom/workspace-next"
  ],

  "modules-right": [
    "custom/browser",
    "custom/terminal",
    "custom/files",
    "custom/swaync"
  ],

  "custom/launcher": {
    "format": "🚀",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/RofiLauncher.sh"
  },

  "custom/browser": {
    "format": "🧭",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/WaybarBrowser.sh"
  },

  "custom/terminal": {
    "format": "📜",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/WaybarTerminal.sh"
  },

  "custom/calendar": {
    "format": "🌎",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/WaybarCmatrix.sh"
  },

  "clock#time": {
    "interval": 30,
    "tooltip": false,
    "format": "{:%H:%M}"
  },

  "clock#date": {
    "interval": 30,
    "tooltip": false,
    "format": "{:%d/%m/%Y}"
  },

  "custom/hour-glyph": {
    "exec": "$HOME/.config/hypr/scripts/WaybarHourGlyph.sh",
    "interval": 60,
    "tooltip": false,
    "format": "{}"
  },

  "custom/workspace-num": {
    "exec": "$HOME/.config/hypr/scripts/WaybarWorkspaceNum.sh",
    "restart-interval": 2,
    "tooltip": false,
    "format": "{}",
    "on-click": "$HOME/.config/hypr/scripts/WaybarAddWorkspace.sh",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },

  "custom/workspace-prev": {
    "format": "⮘",
    "tooltip": false,
    "on-click": "hyprctl dispatch workspace e-1"
  },

  "custom/workspace-next": {
    "format": "⮚",
    "tooltip": false,
    "on-click": "hyprctl dispatch workspace e+1"
  },

  "custom/swaync": {
    "format": "⚙️",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/SwayncPanel.sh toggle",
    "on-click-right": "$HOME/.config/hypr/scripts/SwayncPanel.sh dnd"
  },

  "custom/files": {
    "format": "📑",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/FocusOrLaunch.sh files"
  }
}
